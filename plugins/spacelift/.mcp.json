{
  "mcpServers": {
    "spacelift.spacectl-mcp": {
      "type": "stdio",
      "command": "spacectl",
      "args": ["mcp", "server"],
      "env": {
        "SPACELIFT_API_KEY_ENDPOINT": "${SPACELIFT_API_KEY_ENDPOINT}",
        "SPACELIFT_API_GITHUB_TOKEN": "${SPACELIFT_API_GITHUB_TOKEN}"
      }
    }
  }
}
